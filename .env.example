# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
# Leave blank to run in DEMO MODE (uses seed data, no database needed).

NEXT_PUBLIC_SUPABASE_URL=https://ibavzficwjtdbyexuzkh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Vm9_wmkkhGUPRLMrLWCA0A_s4ITzICL

# ─────────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NWS_USER_AGENT=SoldierHub/1.0 (https://soldierhub.com)

# ─────────────────────────────────────────────────────────────────────────────
# Admin configuration
# ─────────────────────────────────────────────────────────────────────────────
# Server-side admin API allow-list. Keep this private in production.
SOLDIERHUB_ADMIN_EMAILS=admin@example.com

# Optional local/demo-only admin email. This is public because it is bundled into
# the browser for demo mode; live authorization still uses SOLDIERHUB_ADMIN_EMAILS.
NEXT_PUBLIC_SOLDIERHUB_DEMO_ADMIN_EMAIL=admin@soldierhub.local

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Production moderation (OpenAI Moderation API)
# ─────────────────────────────────────────────────────────────────────────────
MODERATION_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT add SUPABASE_SERVICE_ROLE_KEY here unless you actually have a
# server route that needs it. The service role bypasses RLS — adding it
# without a real use case is a security risk.
# ─────────────────────────────────────────────────────────────────────────────

