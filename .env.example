# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
# Leave blank to run in DEMO MODE (uses seed data, no database needed).

NEXT_PUBLIC_SUPABASE_URL=https://ibavzficwjtdbyexuzkh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Vm9_wmkkhGUPRLMrLWCA0A_s4ITzICL

# ─────────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NWS_USER_AGENT=SoldierHub/1.0 (https://soldierhub.com)

# ─────────────────────────────────────────────────────────────────────────────
# Admin configuration
# ─────────────────────────────────────────────────────────────────────────────
# Server-side admin API allow-list. Keep this private in production.
SOLDIERHUB_ADMIN_EMAILS=admin@example.com

# Optional local/demo-only admin email. This is public because it is bundled into
# the browser for demo mode; live authorization still uses SOLDIERHUB_ADMIN_EMAILS.
NEXT_PUBLIC_SOLDIERHUB_DEMO_ADMIN_EMAIL=admin@soldierhub.local

# ─────────────────────────────────────────────────────────────────────────────
# Required in production: shared rate limiter
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_HASH_SECRET=
# Optional tuning. Defaults are 1200 ms and one retry for transient timeouts.
RATE_LIMIT_SHARED_TIMEOUT_MS=1200
RATE_LIMIT_SHARED_RETRIES=1

# ─────────────────────────────────────────────────────────────────────────────
# Required for image upload: Cloudflare R2
# ─────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public/custom-domain base URL used by upload APIs and post image validation.
# Example: https://media.soldierhub.com or https://pub-xxxx.r2.dev
R2_PUBLIC_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Sentry monitoring
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=soldier-hub
SENTRY_PROJECT=soldierhub

# ─────────────────────────────────────────────────────────────────────────────
# Optional but strongly recommended for public beta: production moderation
# ─────────────────────────────────────────────────────────────────────────────
# Server-only key used by src/lib/server/contentSafety.js.
# When set, post text is checked with OpenAI Moderation before insert.
# If unset, the app uses local-only moderation and stores allowed posts as degraded.
OPENAI_API_KEY=
# Backward-compatible alias. Leave blank if OPENAI_API_KEY is set.
MODERATION_API_KEY=
MODERATION_MODEL=omni-moderation-latest

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT add SUPABASE_SERVICE_ROLE_KEY here unless you actually have a
# server route that needs it. The service role bypasses RLS — adding it
# without a real use case is a security risk.
# ─────────────────────────────────────────────────────────────────────────────
